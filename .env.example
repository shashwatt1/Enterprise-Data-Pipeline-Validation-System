# Database — SQLite by default. Swap to PostgreSQL/MySQL by changing the URL.
# SQLite:      sqlite:///./pipeline.db
# PostgreSQL:  postgresql://user:password@localhost:5432/pipeline_db
# MySQL:       mysql+pymysql://user:password@localhost:3306/pipeline_db
DATABASE_URL=sqlite:///./pipeline.db

# Logging
LOG_LEVEL=INFO

# Optional: Google BigQuery
# BIGQUERY_PROJECT_ID=your-gcp-project
# BIGQUERY_DATASET=pipeline_dataset
# BIGQUERY_CREDENTIALS_PATH=./service_account.json
